# Base de données PostgreSQL (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/arlette_commune

# JWT
JWT_SECRET=changez_ce_secret_en_production
JWT_EXPIRES_IN=7d

# Cloudinary (stockage photos)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# Firebase (notifications push)
FIREBASE_PROJECT_ID=votre_projet_firebase
FIREBASE_CLIENT_EMAIL=votre_email_firebase
FIREBASE_PRIVATE_KEY=votre_cle_privee_firebase

# Africa's Talking (SMS OTP - opérateurs ivoiriens)
AT_API_KEY=votre_api_key_africas_talking
AT_USERNAME=votre_username
AT_SENDER_ID=ARLETTE

# Serveur
PORT=3000
NODE_ENV=development
